# Copy to `.env` for local dev and docker-compose substitution.
#
# Full checklist: docs/RUNBOOK.md
#
# Flow:  make setup          → .env + deps
#        make db-dev         → Docker Postgres + local API reload (ignores MySQL DATABASE_URL for that run)
#        make dev            → local API (reload); DB = whatever DATABASE_URL points to (e.g. MySQL)
#        make db             → only start Postgres container (pair with db-dev, or set DATABASE_URL to Postgres)
#        make prod           → nginx + API + Postgres in Docker (see deploy/production/)
#        make docker-local   → uses deploy/local/docker.env (not this file) for Compose vars

# --- Database (pick one) ---
# Use exactly one active DATABASE_URL= line (duplicates confuse pydantic-settings).
# If MySQL schema errors after model changes: DROP DATABASE …; CREATE DATABASE …; restart app.
# MySQL (local or managed). Async app uses aiomysql; you can set either form:
DATABASE_URL=mysql+aiomysql://root:password@localhost:3306/interview_practice_2026
# DATABASE_URL=mysql+pymysql://root:password@localhost:3306/auto_forge

# Supabase (direct): see deploy/supabase/README.md and deploy/supabase/compose.env.example
# DATABASE_URL=postgresql+psycopg2://postgres:PASSWORD@db.<project-ref>.supabase.co:5432/postgres

# Docker Compose default stack still uses Postgres (`make db` / `make prod` without changes).
# For local MySQL you usually skip `make db` and run MySQL yourself.
# DATABASE_URL=postgresql+psycopg2://learn:learn@localhost:5432/moapril

JWT_SECRET_KEY=change-me-use-openssl-rand-hex-32
ACCESS_TOKEN_EXPIRE_MINUTES=1440

CORS_ORIGINS=http://localhost:3000,http://localhost:8080,http://127.0.0.1:8000
RATE_LIMIT_DEFAULT=60/minute

# Optional: create admin on first startup (leave empty to skip)
SEED_ADMIN_EMAIL=
SEED_ADMIN_PASSWORD=

# docker-compose Postgres (only if you use the bundled `db` service)
POSTGRES_USER=learn
POSTGRES_PASSWORD=learn
POSTGRES_DB=moapril
POSTGRES_PUBLISH_PORT=5432

NGINX_HTTP_PORT=8080

# --- Used when running `make prod` (deploy/production/compose.yml) ---
# GUNICORN_WORKERS=4
# GUNICORN_TIMEOUT=120

# --- App identity & logging (IST) ---
# Product name in OpenAPI title, startup line, and access log `application=…` (not the repo folder name).
# APP_NAME=My Application
# Optional: override only the log `application=…` field (OpenAPI title still uses APP_NAME).
# SERVICE_DISPLAY_NAME=
# Live log tail over WebSocket (same text as logs/app.log). Disable on production APIs exposed to untrusted clients.
# LOG_WS_ENABLED=true
# JSON errors: add `debug` with exception, message, and `where` { file, line, function, code? } (dev only).
# API_EXPOSE_INTERNAL_ERRORS=false

# --- Logging format. Default: compact (status, listen URL, DB name + connection, one line per request). ---
# LOG_COMPACT=true        # true = bordered panels + icons + details (default). false = older multi-step lifecycle + optional plain HTTP line
# LOG_CONFIG_BANNER=true  # full settings table (only when LOG_COMPACT=false)
# LOG_LEVEL=INFO
# LOG_LIFECYCLE=true
# LOG_HTTP_ACCESS=true
# LOG_HTTP_SLOW_WARNING_MS=2000
# LOG_RICH_HTTP_PANEL=true

# Optional: `python main.py` / defaults
UVICORN_HOST=0.0.0.0
UVICORN_PORT=8000

# Optional: repo-relative paths (defaults: static, templates, media, upload, logs, topics)
# STATIC_DIR=static
# MEDIA_DIR=media
# UPLOAD_DIR=upload
# LOGS_DIR=logs
# TOPICS_DIR=topics
