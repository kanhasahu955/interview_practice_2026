# Copy to repo-root `.env` on your VPS (never commit real secrets).
#   cp deploy/hostinger/env.hostinger.example .env && nano .env && chmod 600 .env
#
# Full steps: deploy/hostinger/README.md

# --- Secrets (required) ---
JWT_SECRET_KEY=
POSTGRES_PASSWORD=

POSTGRES_USER=learn
POSTGRES_DB=moapril

# Must match POSTGRES_* above (host `db` = Docker service name).
DATABASE_URL=postgresql+psycopg2://learn:YOUR_POSTGRES_PASSWORD@db:5432/moapril

# Your live site(s), comma-separated, no spaces. Include https://www if you use it.
CORS_ORIGINS=https://yourdomain.com,https://www.yourdomain.com

# --- Public branding (optional) ---
# APP_NAME=My Study Site

# --- Docker publish (Hostinger VPS: do not expose Postgres to the internet) ---
POSTGRES_PUBLISH_PORT=127.0.0.1:5432
NGINX_HTTP_PORT=80

# --- Production workers (tune to vCPU count, often 2–4 on small VPS) ---
GUNICORN_WORKERS=2
GUNICORN_TIMEOUT=120
LOG_LEVEL=INFO
RATE_LIMIT_DEFAULT=120/minute

# Optional first admin (leave empty to skip)
SEED_ADMIN_EMAIL=
SEED_ADMIN_PASSWORD=

# Disable WebSocket log stream on untrusted networks (recommended on public VPS).
LOG_WS_ENABLED=false
