# Loaded by `make docker-local` (exported into the shell so it wins over a dev `.env` that points at MySQL).
# Safe to commit — no secrets. Tweak ports here if 5432 or 8080 are busy.

POSTGRES_USER=learn
POSTGRES_PASSWORD=learn
POSTGRES_DB=moapril
POSTGRES_PUBLISH_PORT=5432

NGINX_HTTP_PORT=8080

DATABASE_URL=postgresql+psycopg2://learn:learn@db:5432/moapril

JWT_SECRET_KEY=local-docker-dev-only-change-for-real-deploys
CORS_ORIGINS=http://localhost:8080,http://127.0.0.1:8080,http://localhost:3000,http://127.0.0.1:8000
RATE_LIMIT_DEFAULT=60/minute

SEED_ADMIN_EMAIL=
SEED_ADMIN_PASSWORD=
