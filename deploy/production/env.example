# Production-oriented variables for `make prod` (copy values into repo-root `.env`).
# This file is the checklist for any host or CI/CD pipeline reusing deploy/production/.
#
# Operations index: docs/RUNBOOK.md
# Hostinger VPS: deploy/hostinger/env.hostinger.example + deploy/hostinger/README.md
# Supabase: deploy/supabase/README.md — VPS: make prod-external-db + DATABASE_URL in .env

# --- Required for real deployments ---
# Strong secret; e.g. openssl rand -hex 32
JWT_SECRET_KEY=

# DB user/password/db must match POSTGRES_* when using bundled Compose Postgres.
POSTGRES_USER=learn
POSTGRES_PASSWORD=
POSTGRES_DB=moapril

# Default Compose stack (Postgres in Docker):
# DATABASE_URL=postgresql+psycopg2://learn:YOUR_PASSWORD@db:5432/moapril
# External MySQL instead:
# DATABASE_URL=mysql+aiomysql://user:YOUR_PASSWORD@your-mysql-host:3306/your_db
# Supabase (Postgres) later:
# DATABASE_URL=postgresql+psycopg2://postgres.[ref]:PASSWORD@...pooler.supabase.com:6543/postgres

DATABASE_URL=postgresql+psycopg2://learn:YOUR_PASSWORD@db:5432/moapril

# Your public site / API origins (comma-separated)
CORS_ORIGINS=https://yourdomain.com

# --- Optional tuning (used by deploy/production/compose.yml) ---
GUNICORN_WORKERS=4
GUNICORN_TIMEOUT=120
LOG_LEVEL=INFO
RATE_LIMIT_DEFAULT=120/minute

# Published ports on the host
NGINX_HTTP_PORT=8080
POSTGRES_PUBLISH_PORT=5432

# Optional first admin (leave empty to skip)
SEED_ADMIN_EMAIL=
SEED_ADMIN_PASSWORD=
