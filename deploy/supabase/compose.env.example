# Copy to compose.env (gitignored) and fill the password:
#   cp deploy/supabase/compose.env.example deploy/supabase/compose.env
#
# Used by: make docker-local-supabase
# See: deploy/supabase/README.md

# Database password = Supabase Dashboard → Project Settings → Database → Database password
# URL-encode the password if it contains @ # % etc.
DATABASE_URL=postgresql+psycopg2://postgres:YOUR_DATABASE_PASSWORD@db.tutkjihhixijaqzhfyxk.supabase.co:5432/postgres

NGINX_HTTP_PORT=8080

JWT_SECRET_KEY=local-supabase-docker-change-me
CORS_ORIGINS=http://127.0.0.1:8080,http://localhost:8080
RATE_LIMIT_DEFAULT=60/minute

SEED_ADMIN_EMAIL=
SEED_ADMIN_PASSWORD=

# Optional (production overlay / prod-external-db)
GUNICORN_WORKERS=2
GUNICORN_TIMEOUT=120
LOG_LEVEL=INFO
